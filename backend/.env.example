# Copy this to .env and fill in your values
DATABASE_URL=postgresql://user:password@localhost:5432/qtoday
SECRET_KEY=change-me

# Used by llm/factory.py — required for qa_service to actually call an LLM.
# Groq: cheap/fast judgment calls (subject/topic validation, match disambiguation).
# OpenAI: QA content generation. Provider routing per purpose is configurable
# in the app_settings table (llm_provider_map), not hardcoded.
GROQ_API_KEY=
OPENAI_API_KEY=

# Email (SMTP) — used for signup verification codes
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@yourdomain.com
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_STARTTLS=True
MAIL_SSL_TLS=False
