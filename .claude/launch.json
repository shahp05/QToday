{
    "version":  "0.0.1",
    "configurations":  [
                           {
                               "name":  "frontend",
                               "runtimeExecutable":  "npm",
                               "runtimeArgs":  [
                                                   "run",
                                                   "dev",
                                                   "--prefix",
                                                   "frontend"
                                               ],
                               "port":  5173,
                               "autoPort":  true
                           }
                          ,
                          {
                              "name": "backend",
                              "runtimeExecutable": "backend/myenv/Scripts/uvicorn.exe",
                              "runtimeArgs": ["main:app", "--reload", "--port", "8001", "--app-dir", "backend"],
                              "port": 8001
                          }
                       ]
}
